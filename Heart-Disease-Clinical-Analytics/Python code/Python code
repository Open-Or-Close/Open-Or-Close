def detect_outliers(i):
    #["age", "trestbps", "chol", "thalach", "oldpeak"]



        Q1 = df_clean[i].quantile(0.25)
        Q3 = df_clean[i].quantile(0.75)

        IQR = Q3 - Q1

        lower = Q1 - 1.5 * IQR
        upper = Q3 + 1.5 * IQR

        outlier = df_clean[ (df_clean[i] < lower) | (df_clean[i] > upper)]

        outliers=outlier[i]


        print(f'Outliers are for {i} is: \n {outliers}')

        return outliers

outliers=detect_outliers(i)
print(f'Outliers of {i} is (index,outlier):\n {outliers}')



