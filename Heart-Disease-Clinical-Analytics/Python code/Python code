------------------------------------------
# 3.1.1- T-test (Numerical features)
------------------------------------------

#Is the mean value of feature i different between healthy and diseased patients?

def check_significance_N(i):

    # i shows the numerical feature. Here we test the significance level of the target values against a selected numerical feature
    from scipy.stats import ttest_ind

    disease = df_clean[df_clean["target"] == 1][i]

    healthy = df_clean[df_clean["target"] == 0][i]

    t_stat, p = ttest_ind(disease, healthy, equal_var=False)    # because population variances may differ.

    return p

pN=check_significance_N(i)
threshold = 0.05
if pN < threshold:
    print(f'{i} is significantly associated with Heart disease in this study ')
else:
    print(f'{i} is not significantly associated with Heart disease in this study ')


-------------------------------------------------
# 3.1.2- Chi-square (Categorical features)
--------------------------------------------------

#["Sex", "cp", "fbs", "restecg","exang","slope","thal"]
# We are testing whether is categorical feature related to heart disease?


j=input('Select a category among the categorical features: ')

def check_significance_C(j):

    # j shows the categorical feature. Here we test the significance level of the target values against a selected categorical feature

    from scipy.stats import chi2_contingency

    table = pd.crosstab(df_clean[j],df_clean["target"])

    chi2, p, dof, expected = chi2_contingency(table)

    return p

pC=check_significance_C(j)
threshold = 0.05
if pC < threshold:
    print(f'{j} is significantly associated with Heart disease in this study ')
else:
    print(f'{j} is not significantly associated with Heart disease in this study ')


